<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aerokinesis - WebXR bHaptics</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Arial', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        #xr-container {
            width: 100%;
            height: 100vh;
            position: absolute;
            top: 0;
            left: 0;
        }

        #canvas {
            display: block;
            width: 100%;
            height: 100%;
        }

        .ui-panel {
            position: absolute;
            background: rgba(0, 0, 0, 0.8);
            color: #fff;
            padding: 20px;
            border-radius: 15px;
            font-size: 14px;
            z-index: 1000;
            backdrop-filter: blur(10px);
            border: 2px solid rgba(102, 126, 234, 0.6);
        }

        .status-panel {
            top: 20px;
            left: 20px;
            min-width: 280px;
        }

        .energy-panel {
            bottom: 20px;
            left: 20px;
            text-align: center;
        }

        .bhaptics-panel {
            top: 20px;
            right: 20px;
            min-width: 250px;
        }

        .controls-panel {
            bottom: 20px;
            right: 20px;
            text-align: right;
        }

        h3 {
            color: #667eea;
            margin-bottom: 12px;
            font-size: 16px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .status-item {
            margin: 8px 0;
            padding: 5px 0;
            border-bottom: 1px solid rgba(102, 126, 234, 0.3);
        }

        .status-label {
            color: #aaa;
            font-size: 12px;
        }

        .status-value {
            color: #667eea;
            font-weight: bold;
            font-size: 14px;
        }

        .energy-bar {
            width: 200px;
            height: 30px;
            background: #333;
            border: 2px solid #667eea;
            border-radius: 15px;
            overflow: hidden;
            margin: 10px auto;
        }

        .energy-fill {
            height: 100%;
            background: linear-gradient(90deg, #667eea, #764ba2);
            width: 0%;
            transition: width 0.1s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 12px;
            font-weight: bold;
        }

        .power-state {
            font-size: 18px;
            font-weight: bold;
            margin: 10px 0;
            color: #667eea;
        }

        .hand-state {
            display: inline-block;
            padding: 8px 12px;
            background: rgba(102, 126, 234, 0.3);
            border-radius: 8px;
            margin: 5px;
            font-size: 12px;
        }

        .hand-state.active {
            background: rgba(102, 126, 234, 0.8);
            color: #fff;
        }

        button {
            background: rgba(102, 126, 234, 0.8);
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 12px;
            margin: 5px;
            transition: all 0.3s ease;
        }

        button:hover {
            background: rgba(102, 126, 234, 1);
            transform: translateY(-2px);
        }

        button:active {
            transform: translateY(0);
        }

        .connection-status {
            display: inline-block;
            width: 12px;
            height: 12px;
            border-radius: 50%;
            margin-right: 8px;
            animation: pulse 2s infinite;
        }

        .connection-status.connected {
            background: #4ade80;
        }

        .connection-status.disconnected {
            background: #ef4444;
            animation: none;
        }

        .connection-status.connecting {
            background: #f59e0b;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }

        .alert {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: rgba(0, 0, 0, 0.95);
            color: #667eea;
            padding: 30px 50px;
            border-radius: 15px;
            border: 2px solid #667eea;
            text-align: center;
            z-index: 2000;
            font-size: 18px;
            display: none;
        }

        .alert.show {
            display: block;
            animation: slideIn 0.3s ease;
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translate(-50%, -45%);
            }
            to {
                opacity: 1;
                transform: translate(-50%, -50%);
            }
        }

        .particle {
            position: absolute;
            pointer-events: none;
        }
    </style>
</head>
<body>
    <div id="xr-container">
        <canvas id="canvas"></canvas>
    </div>

    <!-- Status Panel -->
    <div class="ui-panel status-panel">
        <h3>⚡ Aerokinesis</h3>
        <div class="status-item">
            <div class="status-label">XR Status</div>
            <div class="status-value" id="xr-status">Inicializando...</div>
        </div>
        <div class="status-item">
            <div class="status-label">Dispositivo XR</div>
            <div class="status-value" id="xr-device">Detectando...</div>
        </div>
        <div class="status-item">
            <div class="status-label">FPS</div>
            <div class="status-value" id="fps">0</div>
        </div>
    </div>

    <!-- bHaptics Panel -->
    <div class="ui-panel bhaptics-panel">
        <h3>🎮 bHaptics</h3>
        <div class="status-item">
            <span class="connection-status" id="bhaptics-status"></span>
            <span id="bhaptics-text">Desconectado</span>
        </div>
        <div class="status-item" id="bhaptics-devices-list">
            <div class="status-label">Dispositivos: 0</div>
        </div>
        <button onclick="connectBHaptics()">Conectar bHaptics</button>
        <button onclick="testBHaptics()">Test Vibración</button>
        <button onclick="resetBHaptics()">Reset</button>
    </div>

    <!-- Energy Panel -->
    <div class="ui-panel energy-panel">
        <div style="color: #667eea; font-size: 16px; margin-bottom: 10px;">⚡ ENERGÍA</div>
        <div class="energy-bar">
            <div class="energy-fill" id="energy-fill">0%</div>
        </div>
        <div class="power-state" id="power-state">REPOSO</div>
        <div>
            <div class="hand-state" id="left-hand">👐 Izq</div>
            <div class="hand-state" id="right-hand">👐 Der</div>
        </div>
    </div>

    <!-- Controls Panel -->
    <div class="ui-panel controls-panel">
        <div style="margin-bottom: 10px; font-size: 12px; color: #aaa;">CONTROLES</div>
        <button onclick="enterXR()">🥽 Entrar XR</button>
        <button onclick="exitXR()">❌ Salir XR</button>
        <div style="margin-top: 10px; font-size: 11px; color: #888;">
            👊 Cerrar puño = Cargar<br>
            ✋ Palma abierta = Disparar
        </div>
    </div>

    <!-- Alert -->
    <div class="alert" id="alert"></div>

    <!-- bHaptics SDK -->
    <script>
        // bHaptics SDK inline - Importar dinámicamente
        let BHapticsManager = null;
        
        async function initBHapticsSDK() {
            try {
                // Usar CDN de bHaptics o script local
                const script = document.createElement('script');
                script.src = 'https://cdn.jsdelivr.net/npm/@bhaptics/haptics@0.0.1/lib/bhaptics_web.js';
                script.onload = () => {
                    BHapticsManager = window.BHaptics;
                    console.log('bHaptics SDK cargado');
                };
                script.onerror = () => {
                    console.warn('No se pudo cargar bHaptics CDN, usando fallback');
                    initBHapticsLocal();
                };
                document.head.appendChild(script);
            } catch (e) {
                console.warn('Error loading bHaptics SDK:', e);
                initBHapticsLocal();
            }
        }

        function initBHapticsLocal() {
            // Fallback: simulador simple de bHaptics
            BHapticsManager = {
                isConnected: false,
                devices: [],
                connect: async function() {
                    this.isConnected = true;
                    this.devices = ['Left Glove', 'Right Glove'];
                    return true;
                },
                disconnect: async function() {
                    this.isConnected = false;
                    this.devices = [];
                },
                submitDot: async function(deviceName, points, durationMs) {
                    console.log(`[bHaptics] ${deviceName}: ${points.length} puntos, ${durationMs}ms`);
                },
                submitPath: async function(deviceName, path, durationMs) {
                    console.log(`[bHaptics] ${deviceName}: path, ${durationMs}ms`);
                }
            };
        }

        // Mostrar alerta
        function showAlert(message, duration = 3000) {
            const alert = document.getElementById('alert');
            alert.textContent = message;
            alert.classList.add('show');
            setTimeout(() => alert.classList.remove('show'), duration);
        }

        // Conectar bHaptics
        async function connectBHaptics() {
            try {
                const status = document.getElementById('bhaptics-status');
                const text = document.getElementById('bhaptics-text');
                
                status.classList.add('connecting');
                text.textContent = 'Conectando...';
                
                if (BHapticsManager && typeof BHapticsManager.connect === 'function') {
                    await BHapticsManager.connect();
                }
                
                status.classList.remove('connecting');
                status.classList.add('connected');
                text.textContent = 'Conectado';
                
                // Actualizar lista de dispositivos
                updateBHapticsDevices();
                showAlert('✅ bHaptics conectado');
            } catch (e) {
                console.error('Error conectando bHaptics:', e);
                document.getElementById('bhaptics-status').classList.add('disconnected');
                document.getElementById('bhaptics-text').textContent = 'Error';
                showAlert('❌ Error conectando bHaptics');
            }
        }

        function updateBHapticsDevices() {
            const list = document.getElementById('bhaptics-devices-list');
            if (BHapticsManager && BHapticsManager.devices) {
                const count = BHapticsManager.devices.length;
                list.innerHTML = `<div class="status-label">Dispositivos: ${count}</div>`;
                BHapticsManager.devices.forEach(device => {
                    const div = document.createElement('div');
                    div.style.fontSize = '12px';
                    div.style.color = '#667eea';
                    div.style.marginTop = '5px';
                    div.textContent = `• ${device}`;
                    list.appendChild(div);
                });
            }
        }

        async function testBHaptics() {
            try {
                if (!BHapticsManager) return;
                
                // Test patrón para simular viento
                const testPoints = [
                    { x: 0.3, y: 0.5, intensity: 0.8 },
                    { x: 0.5, y: 0.3, intensity: 0.9 },
                    { x: 0.7, y: 0.5, intensity: 0.8 }
                ];
                
                if (BHapticsManager.devices && BHapticsManager.devices.length > 0) {
                    await BHapticsManager.submitDot('Left Glove', testPoints, 500);
                    await BHapticsManager.submitDot('Right Glove', testPoints, 500);
                    showAlert('🎮 Test vibración enviado');
                }
            } catch (e) {
                console.error('Error en test bHaptics:', e);
            }
        }

        function resetBHaptics() {
            if (BHapticsManager && typeof BHapticsManager.disconnect === 'function') {
                BHapticsManager.disconnect();
                document.getElementById('bhaptics-status').classList.remove('connected');
                document.getElementById('bhaptics-status').classList.add('disconnected');
                document.getElementById('bhaptics-text').textContent = 'Desconectado';
                showAlert('Reset bHaptics');
            }
        }

        // Inicializar bHaptics SDK
        initBHapticsSDK();
    </script>

    <!-- Three.js y WebXR -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script>
        // ============ THREE.JS SCENE SETUP ============
        let scene, camera, renderer, xrSession = null;
        let canvas = document.getElementById('canvas');
        
        // Hand tracking
        let hands = { left: null, right: null };
        let handPoses = {
            left: { position: new THREE.Vector3(-0.3, 0, -0.5), closed: false },
            right: { position: new THREE.Vector3(0.3, 0, -0.5), closed: false }
        };

        // Energy system
        let energy = 0;
        let maxEnergy = 100;
        let isCharging = false;
        let isPowering = false;

        // Visual effects
        let windField = null;
        let particles = [];
        let windStrength = 0;

        // Initialize scene
        function initScene() {
            // Scene
            scene = new THREE.Scene();
            scene.background = new THREE.Color(0x1a1a2e);
            scene.fog = new THREE.Fog(0x1a1a2e, 50, 100);

            // Camera
            camera = new THREE.PerspectiveCamera(
                75,
                window.innerWidth / window.innerHeight,
                0.1,
                1000
            );
            camera.position.set(0, 1.6, 0);

            // Renderer
            renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.setPixelRatio(window.devicePixelRatio);
            renderer.xr.enabled = true;
            renderer.xr.setReferenceSpaceType('local');

            // Lighting
            const ambientLight = new THREE.AmbientLight(0xffffff, 0.6);
            scene.add(ambientLight);

            const directionalLight = new THREE.DirectionalLight(0xffffff, 0.8);
            directionalLight.position.set(5, 10, 5);
            scene.add(directionalLight);

            // Energy sphere (centro de poder)
            const sphereGeom = new THREE.SphereGeometry(0.3, 32, 32);
            const sphereMat = new THREE.MeshStandardMaterial({
                color: 0x667eea,
                emissive: 0x667eea,
                emissiveIntensity: 0.5,
                metalness: 0.8,
                roughness: 0.2
            });
            windField = new THREE.Mesh(sphereGeom, sphereMat);
            windField.position.set(0, 1.6, -2);
            scene.add(windField);

            // Wind effect particles
            createWindParticles();

            // Environment
            createEnvironment();

            window.addEventListener('resize', onWindowResize);
            renderer.xr.addEventListener('sessionstart', onSessionStart);
            renderer.xr.addEventListener('sessionend', onSessionEnd);

            document.getElementById('xr-status').textContent = 'Listo';
        }

        function createEnvironment() {
            // Ground
            const groundGeom = new THREE.PlaneGeometry(20, 20);
            const groundMat = new THREE.MeshStandardMaterial({
                color: 0x2a2a3e,
                roughness: 0.8
            });
            const ground = new THREE.Mesh(groundGeom, groundMat);
            ground.rotation.x = -Math.PI / 2;
            ground.position.y = 0;
            scene.add(ground);

            // Ambient cubes (decoración)
            for (let i = 0; i < 5; i++) {
                const geom = new THREE.BoxGeometry(0.5, 0.5, 0.5);
                const mat = new THREE.MeshStandardMaterial({
                    color: new THREE.Color().setHSL(Math.random(), 0.7, 0.5),
                    metalness: 0.5,
                    roughness: 0.5
                });
                const cube = new THREE.Mesh(geom, mat);
                cube.position.set(
                    (Math.random() - 0.5) * 10,
                    0.5,
                    (Math.random() - 0.5) * 10
                );
                scene.add(cube);
            }
        }

        function createWindParticles() {
            const particleCount = 500;
            const geometry = new THREE.BufferGeometry();
            const positions = new Float32Array(particleCount * 3);

            for (let i = 0; i < particleCount; i++) {
                positions[i * 3] = (Math.random() - 0.5) * 20;
                positions[i * 3 + 1] = Math.random() * 5;
                positions[i * 3 + 2] = (Math.random() - 0.5) * 20;
            }

            geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));

            const material = new THREE.PointsMaterial({
                color: 0x667eea,
                size: 0.1,
                sizeAttenuation: true,
                transparent: true,
                opacity: 0.6
            });

            particles = new THREE.Points(geometry, material);
            particles.userData.velocity = new Float32Array(particleCount * 3);
            scene.add(particles);
        }

        function updateWindEffect() {
            if (!particles || !windField) return;

            const positions = particles.geometry.attributes.position.array;
            const velocity = particles.userData.velocity;
            const windFieldPos = windField.position;

            windStrength = isCharging ? energy / maxEnergy : (isPowering ? 1 : 0);

            for (let i = 0; i < positions.length; i += 3) {
                let px = positions[i];
                let py = positions[i + 1];
                let pz = positions[i + 2];

                // Dirección desde partícula hacia campo
                const dx = windFieldPos.x - px;
                const dy = windFieldPos.y - py;
                const dz = windFieldPos.z - pz;
                const dist = Math.sqrt(dx * dx + dy * dy + dz * dz);

                if (dist < 5) {
                    velocity[i] += (dx / dist) * windStrength * 0.5;
                    velocity[i + 1] += (dy / dist) * windStrength * 0.5;
                    velocity[i + 2] += (dz / dist) * windStrength * 0.5;
                }

                // Aplicar velocidad
                positions[i] += velocity[i];
                positions[i + 1] += velocity[i + 1];
                positions[i + 2] += velocity[i + 2];

                // Damping
                velocity[i] *= 0.95;
                velocity[i + 1] *= 0.95;
                velocity[i + 2] *= 0.95;

                // Reset si se sale del rango
                if (dist > 30) {
                    positions[i] = (Math.random() - 0.5) * 20;
                    positions[i + 1] = Math.random() * 5;
                    positions[i + 2] = (Math.random() - 0.5) * 20;
                    velocity[i] = 0;
                    velocity[i + 1] = 0;
                    velocity[i + 2] = 0;
                }
            }

            particles.geometry.attributes.position.needsUpdate = true;

            // Animar esfera de energía
            windField.scale.set(
                1 + windStrength * 0.3,
                1 + windStrength * 0.3,
                1 + windStrength * 0.3
            );

            const mat = windField.material;
            mat.emissiveIntensity = 0.5 + windStrength * 0.5;
        }

        function updateEnergy() {
            if (isCharging && energy < maxEnergy) {
                energy += 1.5;
                if (energy > maxEnergy) energy = maxEnergy;
            } else if (!isCharging && !isPowering && energy > 0) {
                energy -= 0.5;
                if (energy < 0) energy = 0;
            }

            // Actualizar UI
            const fill = document.getElementById('energy-fill');
            const percent = Math.round((energy / maxEnergy) * 100);
            fill.style.width = percent + '%';
            fill.textContent = percent + '%';

            // Estado
            let state = 'REPOSO';
            if (isCharging) state = '⚡ CARGANDO';
            if (isPowering) state = '💨 DISPARANDO';
            if (energy === maxEnergy && isCharging) state = '🔋 MÁXIMO';

            document.getElementById('power-state').textContent = state;
        }

        function updateHandTracking(frame) {
            const session = frame.session;
            const inputSources = session.inputSources;

            for (const source of inputSources) {
                if (source.hand) {
                    const handedness = source.handedness;
                    const hand = source.hand;

                    try {
                        const indexTip = hand.get('index-finger-tip');
                        const thumbTip = hand.get('thumb-tip');
                        const palmPos = hand.get('palm');

                        if (indexTip && thumbTip) {
                            const indexPose = frame.getJointPose(indexTip, frame.referenceSpace);
                            const thumbPose = frame.getJointPose(thumbTip, frame.referenceSpace);

                            if (indexPose && thumbPose) {
                                const distance = indexPose.transform.position.distanceTo(
                                    thumbPose.transform.position
                                );

                                // Detección puño cerrado
                                const closed = distance < 0.05;
                                
                                if (handedness === 'left') {
                                    handPoses.left.closed = closed;
                                    document.getElementById('left-hand').classList.toggle('active', closed);
                                    if (closed) {
                                        isCharging = true;
                                        showHandFeedback('left');
                                    }
                                } else {
                                    handPoses.right.closed = closed;
                                    document.getElementById('right-hand').classList.toggle('active', closed);
                                    if (closed) {
                                        isCharging = true;
                                        showHandFeedback('right');
                                    }
                                }

                                // Detectar apertura de palma para disparar
                                if (!closed && handPoses[handedness].closed) {
                                    triggerAerokinesis(handedness);
                                }
                            }
                        }
                    } catch (e) {
                        // Hand tracking not available
                    }
                }
            }

            // Si no hay puño cerrado, detener carga
            if (!handPoses.left.closed && !handPoses.right.closed) {
                isCharging = false;
            }
        }

        function showHandFeedback(hand) {
            // Retroalimentación visual
            if (windField) {
                windField.material.emissive.setHex(0x667eea);
            }
        }

        async function triggerAerokinesis(hand) {
            isPowering = true;
            const strength = energy / maxEnergy;

            // Enviar vibración a bHaptics
            if (BHapticsManager && BHapticsManager.isConnected) {
                const glove = hand === 'left' ? 'Left Glove' : 'Right Glove';
                const points = [];

                for (let i = 0; i < 15; i++) {
                    points.push({
                        x: Math.random(),
                        y: Math.random(),
                        intensity: 0.5 + strength * 0.5
                    });
                }

                try {
                    if (typeof BHapticsManager.submitDot === 'function') {
                        await BHapticsManager.submitDot(glove, points, 200 + strength * 300);
                    }
                } catch (e) {
                    console.log('bHaptics submitDot no disponible');
                }
            }

            // Efectos visuales
            createAerokinesisBurst(hand, strength);

            // Consumir energía
            energy = 0;

            setTimeout(() => {
                isPowering = false;
            }, 300);
        }

        function createAerokinesisBurst(hand, strength) {
            // Crear explosión de aire
            const burstGeom = new THREE.SphereGeometry(0.5 + strength, 16, 16);
            const burstMat = new THREE.MeshBasicMaterial({
                color: 0x667eea,
                transparent: true,
                opacity: 0.6,
                wireframe: true
            });
            const burst = new THREE.Mesh(burstGeom, burstMat);

            const handPos = hand === 'left' ? 
                handPoses.left.position : handPoses.right.position;

            burst.position.copy(handPos);
            scene.add(burst);

            // Animar expansión
            let scale = 1;
            const expandInterval = setInterval(() => {
                scale += 0.1;
                burst.scale.set(scale, scale, scale);
                burst.material.opacity -= 0.05;

                if (scale > 3) {
                    clearInterval(expandInterval);
                    scene.remove(burst);
                }
            }, 30);
        }

        // XR Functions
        async function enterXR() {
            try {
                const canvas = document.getElementById('canvas');
                const session = await navigator.xr.requestSession('immersive-vr', {
                    requiredFeatures: ['hand-tracking', 'dom-overlay'],
                    domOverlay: { root: document.body }
                });

                xrSession = session;
                const refSpace = await session.requestReferenceSpace('local');
                renderer.xr.setSession(session, refSpace);

                document.getElementById('xr-status').textContent = 'En sesión XR';
                document.getElementById('xr-device').textContent = 'Quest 3S (Activo)';
                showAlert('🥽 Sesión XR iniciada');

                renderer.xr.getSession().addEventListener('selectstart', onSelectStart);
                renderer.xr.getSession().addEventListener('selectend', onSelectEnd);
            } catch (e) {
                console.error('Error iniciando XR:', e);
                document.getElementById('xr-status').textContent = 'XR no disponible';
                showAlert('❌ XR no disponible en este dispositivo');
            }
        }

        function exitXR() {
            if (xrSession) {
                xrSession.end();
            }
        }

        function onSessionStart() {
            document.getElementById('xr-status').textContent = 'Sesión activa';
        }

        function onSessionEnd() {
            xrSession = null;
            document.getElementById('xr-status').textContent = 'Sesión cerrada';
            document.getElementById('xr-device').textContent = 'Desconectado';
        }

        function onSelectStart(event) {
            // Simulación de click/trigger
        }

        function onSelectEnd(event) {
            // Simulación de release
        }

        // Animation loop
        let lastTime = Date.now();
        let frameCount = 0;

        renderer.xr.setAnimationLoop((time, frame) => {
            frameCount++;
            const now = Date.now();
            if (now - lastTime >= 1000) {
                document.getElementById('fps').textContent = frameCount;
                frameCount = 0;
                lastTime = now;
            }

            if (frame) {
                updateHandTracking(frame);
            }

            updateEnergy();
            updateWindEffect();

            renderer.render(scene, camera);
        });

        function onWindowResize() {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        }

        // Initialize
        document.addEventListener('DOMContentLoaded', initScene);

        // Keyboard fallback para testing
        document.addEventListener('keydown', (e) => {
            if (e.key === 'c') isCharging = true;
            if (e.key === 'p') triggerAerokinesis('right');
        });

        document.addEventListener('keyup', (e) => {
            if (e.key === 'c') isCharging = false;
        });
    </script>
</body>
</html>
